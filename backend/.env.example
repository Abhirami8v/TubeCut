# Server
PUBLIC_BASE_URL=http://127.0.0.1:8000
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Database (defaults to local sqlite file if unset)
DATABASE_URL=sqlite:///./tubecut.db

# Gemini (transcript analysis / clip segmentation)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# YouTube Data API v3 (optional: richer metadata / future Shorts auto-publish)
YOUTUBE_DATA_API_KEY=

# Whisper
WHISPER_MODEL_SIZE=small
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# YOLO weights path (auto-downloaded by ultralytics on first run if missing)
YOLO_WEIGHTS_PATH=yolov8n.pt
