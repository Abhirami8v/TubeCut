# Server
PUBLIC_BASE_URL=http://127.0.0.1:8000
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://tube-cut.vercel.app

# Database (defaults to local sqlite file if unset)
DATABASE_URL=sqlite:///./tubecut.db

# Gemini (transcript analysis / clip segmentation) — REQUIRED on Render
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
TRANSCRIPTION_ENGINE=gemini

# YouTube Data API v3 (optional: richer metadata / future Shorts auto-publish)
YOUTUBE_DATA_API_KEY=

# YouTube download on cloud hosts (REQUIRED on Render)
# Export cookies from your logged-in browser:
#   yt-dlp --cookies-from-browser chrome --cookies storage/cookies.txt "https://youtube.com"
# Then paste the entire cookies.txt file contents into YT_DLP_COOKIES_CONTENT on Render.
YT_DLP_COOKIES_CONTENT=
YT_DLP_COOKIES_PATH=
YT_DLP_PROXY=
YT_DLP_PO_TOKEN=

# Whisper
WHISPER_MODEL_SIZE=small
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# YOLO weights path (auto-downloaded by ultralytics on first run if missing)
YOLO_WEIGHTS_PATH=yolov8n.pt
ASSEMBLYAI_API=
GROK_API=